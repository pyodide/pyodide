From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Gyeongjae Choi <def6488@gmail.com>
Date: Tue, 20 May 2026 00:00:00 +0900
Subject: [PATCH 10/10] Use emscripten_stack_get_current() for
 _Py_get_machine_stack_pointer on Emscripten

On Emscripten/wasm, __builtin_frame_address(0) can cause LLVM to emit
code that saves and later restores the __stack_pointer wasm global.
If an external stack manager (such as JSPI stack switching) modifies
__stack_pointer while that C frame is active, the C function's return
will overwrite the externally restored value with its stale saved copy,
causing a persistent stack pointer drift.

emscripten_stack_get_current() reads the current Emscripten stack pointer
without causing this side effect. It is also consistent with how CPython
already initializes stack bounds on Emscripten using
emscripten_stack_get_base() and emscripten_stack_get_end().
---
 Include/internal/pycore_pystate.h | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/Include/internal/pycore_pystate.h b/Include/internal/pycore_pystate.h
--- a/Include/internal/pycore_pystate.h
+++ b/Include/internal/pycore_pystate.h
@@ -11,6 +11,10 @@
 #include "pycore_pythonrun.h"     // _PyOS_STACK_MARGIN_SHIFT
 #include "pycore_typedefs.h"      // _PyRuntimeState
 #include "pycore_tstate.h"
+
+#ifdef __EMSCRIPTEN__
+#include <emscripten/stack.h>     // emscripten_stack_get_current
+#endif
 
 
 // Values for PyThreadState.state. A thread must be in the "attached" state
@@ -309,7 +313,9 @@
 
 static inline uintptr_t
 _Py_get_machine_stack_pointer(void) {
-#if _Py__has_builtin(__builtin_frame_address) || defined(__GNUC__)
+#if defined(__EMSCRIPTEN__)
+    return (uintptr_t)emscripten_stack_get_current();
+#elif _Py__has_builtin(__builtin_frame_address) || defined(__GNUC__)
     return (uintptr_t)__builtin_frame_address(0);
 #elif defined(_MSC_VER)
     return (uintptr_t)_AddressOfReturnAddress();
